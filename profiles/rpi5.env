# Shell profile for a generic Raspberry Pi 5 test deployment.

export DEVICE_PROFILE="rpi5"
export PROJECT_ROOT="${PROJECT_ROOT:-${HOME}/device_connect}"
export VENV_DIR="${VENV_DIR:-.venv}"

export DEVICE_TYPE="${DEVICE_TYPE:-raspberry_pi}"
export PUPPYPI_CONTAINER="${PUPPYPI_CONTAINER:-test}"
export ROS_SETUP="${ROS_SETUP:-/opt/ros/humble/setup.bash}"
export PUPPYPI_SETUP="${PUPPYPI_SETUP:-/home/ubuntu/ros2_ws/install/setup.bash}"

export FABRIC_CREDENTIALS_FILE="${FABRIC_CREDENTIALS_FILE:-${PROJECT_ROOT}/puppy-device-connect/rpi5-test.creds.json}"
