# Shell profile for the real Hiwonder PuppyPi deployment.

export DEVICE_PROFILE="puppypi"
export PROJECT_ROOT="${PROJECT_ROOT:-/home/pi/device_connect}"
export VENV_DIR="${VENV_DIR:-venv}"

export DEVICE_TYPE="${DEVICE_TYPE:-quadruped}"
export PUPPYPI_CONTAINER="${PUPPYPI_CONTAINER:-puppypi_ros2}"
export ROS_SETUP="${ROS_SETUP:-/opt/ros/humble/setup.bash}"
export PUPPYPI_SETUP="${PUPPYPI_SETUP:-/home/ubuntu/ros2_ws/install/setup.bash}"

export FABRIC_CREDENTIALS_FILE="${FABRIC_CREDENTIALS_FILE:-${PROJECT_ROOT}/puppy-device-connect/beta-odin-puppypi.creds.json}"
